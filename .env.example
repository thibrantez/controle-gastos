# ══════════════════════════════════════════════════════════════════
#  Variáveis de ambiente — Controle de Gastos
#
#  Local:  copie este arquivo para .env.local e preencha os valores.
#  Vercel: adicione cada variável em:
#          Project Settings → Environment Variables
# ══════════════════════════════════════════════════════════════════


# ── Google OAuth2 ──────────────────────────────────────────────────
#
# Como obter:
#   1. Acesse https://console.cloud.google.com/apis/credentials
#   2. Ative a Google Sheets API no projeto
#   3. Crie um "ID do cliente OAuth 2.0" do tipo "App para computador"
#   4. Copie Client ID e Client Secret abaixo
#   5. Execute  node scripts/get-token.mjs  para obter o Refresh Token

GOOGLE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-SEU_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=SEU_REFRESH_TOKEN

# ── Google Sheets ──────────────────────────────────────────────────
#
# GOOGLE_SPREADSHEET_ID: extraia da URL da planilha:
#   https://docs.google.com/spreadsheets/d/  ESTE_TRECHO  /edit
#
# GOOGLE_SHEET_NAME: nome exato da aba (padrão já configurado abaixo)

GOOGLE_SPREADSHEET_ID=1zjrOdIeqUN7hf1i0qqxQBEa9BU5fhTEadKDwt9BIbOw
GOOGLE_SHEET_NAME=Gastos & Dashboard
